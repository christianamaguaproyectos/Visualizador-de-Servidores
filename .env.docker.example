# ===========================================
# Variables de entorno para Docker
# Copia este archivo a .env y modifica los valores
# ===========================================

# === Base de Datos PostgreSQL ===
POSTGRES_USER=diagrama
POSTGRES_PASSWORD=DiagramaServers2025
POSTGRES_DB=diagrama_servers
POSTGRES_PORT=5432

# === Aplicación ===
APP_PORT=3000
SESSION_SECRET=GrupoDanec-DiagramaServidores-2025-MiSecretoSeguro

# === Monitoreo ===
MONITORING_ENABLED=1

# === Notificaciones por Email (Opcional) ===
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=usuario@empresa.com
# SMTP_PASS=contraseña
# ALERT_EMAIL_TO=admin@empresa.com,soporte@empresa.com

# === Microsoft Teams (Opcional) ===
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# === Timeouts de Checks (ms) ===
DEFAULT_PING_TIMEOUT_MS=2000
DEFAULT_TCP_TIMEOUT_MS=2000
DEFAULT_HTTP_TIMEOUT_MS=3000
