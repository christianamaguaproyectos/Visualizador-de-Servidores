# Patrones a ignorar en builds de Docker
node_modules
npm-debug.log*
.git
.gitignore

# Archivos de configuración local
.env
.env.local
.env.*.local
config.json

# Logs y datos temporales
logs/
*.log

# Archivos de IDE
.vscode/
.idea/
*.swp
*.swo

# Archivos de sistema
.DS_Store
Thumbs.db

# Documentación no necesaria en producción
*.md
!README.md

# Tests (si los hubiera)
__tests__/
*.test.js
*.spec.js
coverage/

# Archivos de desarrollo
nodemon.json
ecosystem.config.cjs
*.bat
*.ps1

# Package lock alternativo
yarn.lock
pnpm-lock.yaml
